# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/autoblog.db
# DATABASE_URL=postgresql://user:password@host:5432/autoblog

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Custom base URL (opsional) - gunakan untuk OpenAI-compatible APIs seperti:
# OpenRouter  : https://openrouter.ai/api/v1
# LM Studio   : http://localhost:1234/v1
# Ollama      : http://localhost:11434/v1
# Azure OpenAI: https://<resource>.openai.azure.com/openai/deployments/<deploy>
# Kosongkan untuk menggunakan endpoint default OpenAI (https://api.openai.com/v1)
OPENAI_BASE_URL=

# WordPress
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your-username
WORDPRESS_APP_PASSWORD=your-application-password

# Image Providers (priority order: unsplash > pexels > pixabay > wikimedia)
IMAGE_PROVIDER=unsplash
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
PEXELS_API_KEY=your-pexels-api-key
PIXABAY_API_KEY=your-pixabay-api-key

# Assets
DEFAULT_THUMBNAIL_PATH=/app/assets/default_thumbnail.webp
COMPANY_LOGO_PATH=/app/assets/logo.png

# Telegram Bot
# 1. Buat bot via @BotFather di Telegram → dapat token
# 2. Tambahkan bot ke group/channel kamu
# 3. Dapatkan chat_id: kirim pesan ke bot, lalu buka
#    https://api.telegram.org/bot<TOKEN>/getUpdates → cari field "chat":{"id":...}
# Untuk personal chat: gunakan ID user kamu (positif)
# Untuk group: gunakan ID group (negatif, contoh: -1001234567890)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# n8n
N8N_USER=admin
N8N_PASSWORD=admin123
N8N_WEBHOOK_URL=http://n8n:5678

# Scheduler (standalone mode, cron expression - default: 6 AM WIB)
SCHEDULER_CRON=0 6 * * *
TIMEZONE=Asia/Jakarta
